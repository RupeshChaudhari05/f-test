{
  "name": "posh-notification-system",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS push notification platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "sdk",
    "wordpress-plugin"
  ],
  "scripts": {
    "configure": "node scripts/configure.js",
    "configure:prod": "node scripts/configure.js --env .env.production",
    "backend:dev": "cd backend && npm run start:dev",
    "backend:build": "cd backend && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "db:migrate": "cd backend && npm run migration:run",
    "db:seed": "cd backend && npm run seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}