# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=posh
DB_PASSWORD=posh_secret_password
DB_NAME=posh_notifications

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Web Push VAPID Keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@poshnotify.com

# Firebase (optional - for FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Super Admin
SUPER_ADMIN_EMAIL=admin@poshnotify.com
SUPER_ADMIN_PASSWORD=change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# SDK CDN URL
SDK_CDN_URL=http://localhost:3000/sdk
