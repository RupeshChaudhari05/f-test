# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# 1. Fill in every value below with your real production details
# 2. Run:  node scripts/configure.js --env .env.production
# 3. Restart your backend and frontend
# =============================================================================

NODE_ENV=production

# -----------------------------------------------------------------------------
# URLS — change these to your real domain
# -----------------------------------------------------------------------------
BACKEND_URL=https://posh.fontgenerator.club
FRONTEND_URL=https://posh.fontgenerator.club

# -----------------------------------------------------------------------------
# Database — your production MySQL server
# -----------------------------------------------------------------------------
DB_TYPE=mysql
DB_HOST=your-db-host.com
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_strong_db_password
DB_NAME=posh_notifications

# -----------------------------------------------------------------------------
# Auth — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRATION=7d

# -----------------------------------------------------------------------------
# VAPID keys — KEEP the same keys you used in development
# (changing them will invalidate ALL existing browser subscriptions)
# -----------------------------------------------------------------------------
VAPID_SUBJECT=mailto:admin@posh.fontgenerator.club
VAPID_PUBLIC_KEY=BJLMAMTTGYU3J-wGhDVDkYw08wYhO2xaRqolP9HoADkfcbpbSNTzLPWrRYVVcjhwlX8rpNvaDHp2KivvEzj3pzo
VAPID_PRIVATE_KEY=2PLmqnZ4hBr3YrpVcMcVcDm-FFzsl2DhWBhfChZnOLQ

# -----------------------------------------------------------------------------
# Redis (optional — for background queues)
# Leave blank if not using Redis
# -----------------------------------------------------------------------------
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# Super Admin
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@posh.fontgenerator.club
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
